// =============================================================================
// FinZap — Prisma Schema
// =============================================================================

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum TransactionKind {
  EXPENSE
  INCOME
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum BotConnectionStatus {
  CONNECTED
  DISCONNECTED
  QR_PENDING
}

enum RecurrenceInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum Role {
  USER
  ADMIN
}

// =============================================================================
// Models
// =============================================================================

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  emailVerified       DateTime?
  passwordHash        String?   // null para usuários OAuth
  image               String?
  role                Role      @default(USER)

  // WhatsApp
  whatsappNumber      String?   @unique // formato: 5511999999999
  whatsappVerifiedAt  DateTime?

  // Stripe
  stripeCustomerId    String?   @unique

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relações
  accounts            Account[]
  sessions            Session[]
  transactions        Transaction[]
  categories          Category[]    // categorias customizadas do usuário
  budgets             Budget[]
  subscription        Subscription?
  whatsappLinkCodes   WhatsappLinkCode[]
  recurringTransactions RecurringTransaction[]

  @@map("users")
}

// Auth.js — tabelas necessárias para o adaptador Prisma
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// Domínio financeiro
// =============================================================================

model Category {
  id        String          @id @default(cuid())
  // userId = null → categoria padrão do sistema (disponível a todos)
  // userId preenchido → categoria customizada do usuário
  userId    String?
  name      String
  icon      String          @default("💰") // emoji ou nome de ícone
  kind      TransactionKind // se é categoria de gasto ou receita

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets      Budget[]

  @@unique([userId, name]) // evita duplicata por usuário
  @@map("categories")
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  categoryId  String?

  amount      Decimal         @db.Decimal(12, 2) // positivo sempre; kind define se é gasto/receita
  kind        TransactionKind
  description String?
  occurredAt  DateTime        @default(now())

  // Rastreabilidade
  source      String          @default("manual") // "manual" | "whatsapp"
  // rawMessage: NUNCA logado externamente; armazenado para auditoria interna
  // criptografado em repouso (Fase 7) — por ora, salvo como texto
  rawMessage  String?         @db.Text

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recurringTransaction   RecurringTransaction? @relation("RecurringToTransaction", fields: [recurringTransactionId], references: [id], onDelete: SetNull)
  recurringTransactionId String?

  @@index([userId, occurredAt])
  @@index([userId, categoryId])
  @@map("transactions")
}

model Budget {
  id           String   @id @default(cuid())
  userId       String
  categoryId   String
  monthlyLimit Decimal  @db.Decimal(12, 2)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId]) // um orçamento por categoria por usuário
  @@map("budgets")
}

model RecurringTransaction {
  id          String             @id @default(cuid())
  userId      String
  categoryId  String?

  amount      Decimal            @db.Decimal(12, 2)
  kind        TransactionKind
  description String?
  
  interval    RecurrenceInterval
  startDate   DateTime
  endDate     DateTime?
  nextDate    DateTime
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  transactions Transaction[]     @relation("RecurringToTransaction")

  @@index([userId])
  @@index([nextDate])
  @@map("recurring_transactions")
}

// =============================================================================
// WhatsApp
// =============================================================================

model WhatsappLinkCode {
  id        String    @id @default(cuid())
  userId    String
  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@map("whatsapp_link_codes")
}

// Status do bot central (única linha — upsert por id fixo "bot")
model BotConnection {
  id              String              @id @default("bot")
  status          BotConnectionStatus @default(DISCONNECTED)
  lastConnectedAt DateTime?
  updatedAt       DateTime            @updatedAt

  @@map("bot_connections")
}

// Sessão Baileys persistida no banco (evita perda em deploys com container efêmero)
model BotAuthState {
  id        String   @id // chave da sessão Baileys (ex.: "creds", "app-state-sync-key-*")
  data      String   @db.Text // JSON serializado
  updatedAt DateTime @updatedAt

  @@map("bot_auth_states")
}

// =============================================================================
// Monetização
// =============================================================================

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus @default(INACTIVE)
  plan                 String             // "free" | "pro"
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
