// =============================================================================
// FinZap — Prisma Schema
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum TransactionKind {
  EXPENSE
  INCOME
}

enum FinancialAccountType {
  CHECKING
  SAVINGS
  CASH
  CREDIT_CARD
  INVESTMENT
  OTHER
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

enum BotConnectionStatus {
  CONNECTED
  DISCONNECTED
  QR_PENDING
}

enum WhatsappInboundStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum RecurrenceInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum Role {
  USER
  ADMIN
}

enum SecurityEventType {
  LOGIN
  PASSWORD_SET
  PASSWORD_CHANGED
  SESSIONS_REVOKED
}

// =============================================================================
// Models
// =============================================================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String? // null para usuários OAuth
  image          String?
  role           Role      @default(USER)
  // Incrementado ao trocar a senha para invalidar JWTs emitidos anteriormente.
  sessionVersion Int       @default(0)

  // WhatsApp
  whatsappNumber     String?   @unique // formato: 5511999999999
  whatsappVerifiedAt DateTime?

  // Stripe
  stripeCustomerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  accounts               Account[]
  sessions               Session[]
  transactions           Transaction[]
  categories             Category[] // categorias customizadas do usuário
  budgets                Budget[]
  billReminders          BillReminder[]
  subscription           Subscription?
  whatsappLinkCodes      WhatsappLinkCode[]
  accountActivationToken AccountActivationToken?
  recurringTransactions  RecurringTransaction[]
  financialAccounts      FinancialAccount[]
  financialGoals         FinancialGoal[]
  transactionRules       TransactionRule[]
  accountReconciliations AccountReconciliation[]
  securityEvents         SecurityEvent[]
  creditCardPayments     CreditCardPayment[]

  @@map("users")
}

// Auth.js — tabelas necessárias para o adaptador Prisma
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model SecurityEvent {
  id        String            @id @default(cuid())
  userId    String
  type      SecurityEventType
  provider  String?
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("security_events")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  attempts   Int      @default(0)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================================================
// Domínio financeiro
// =============================================================================

model Category {
  id     String          @id @default(cuid())
  // userId = null → categoria padrão do sistema (disponível a todos)
  // userId preenchido → categoria customizada do usuário
  userId String?
  name   String
  icon   String          @default("💰") // emoji ou nome de ícone
  kind   TransactionKind // se é categoria de gasto ou receita

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]
  transactionRules      TransactionRule[]

  @@unique([userId, name]) // evita duplicata por usuário
  @@map("categories")
}

model FinancialAccount {
  id             String               @id @default(cuid())
  userId         String
  name           String
  type           FinancialAccountType
  initialBalance Decimal              @default(0) @db.Decimal(12, 2)
  creditLimit    Decimal?             @db.Decimal(12, 2)
  closingDay     Int?
  dueDay         Int?
  isArchived     Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user                 User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         Transaction[]
  transactionRules     TransactionRule[]
  reconciliations      AccountReconciliation[]
  creditCardPayments   CreditCardPayment[]     @relation("CreditCardPayments")
  invoicePaymentSources CreditCardPayment[]    @relation("CreditCardPaymentSources")

  @@unique([userId, name])
  @@index([userId, isArchived])
  @@map("financial_accounts")
}

model Transaction {
  id                 String  @id @default(cuid())
  userId             String
  categoryId         String?
  financialAccountId String?

  amount      Decimal         @db.Decimal(12, 2) // positivo sempre; kind define se é gasto/receita
  kind        TransactionKind
  description String?
  occurredAt  DateTime        @default(now())

  // Cartão de crédito e parcelamento
  installmentGroupId String?
  installmentNumber  Int?
  installmentCount   Int?
  originalAmount     Decimal? @db.Decimal(12, 2)
  purchasedAt        DateTime?
  cardStatementDate  DateTime?
  cardDueDate        DateTime?

  // Rastreabilidade
  source            String  @default("manual") // "manual" | "whatsapp" | "recurring" | "import"
  // rawMessage: NUNCA logado externamente; armazenado para auditoria interna
  // criptografado em repouso (Fase 7) — por ora, salvo como texto
  rawMessage        String? @db.Text
  externalMessageId String? @unique // idempotência para mensagens do WhatsApp
  importFingerprint String?
  reconciliationId  String?
  appliedRuleId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category               Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  financialAccount       FinancialAccount?      @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  reconciliation         AccountReconciliation? @relation(fields: [reconciliationId], references: [id], onDelete: SetNull)
  appliedRule            TransactionRule?       @relation(fields: [appliedRuleId], references: [id], onDelete: SetNull)
  recurringTransaction   RecurringTransaction?  @relation("RecurringToTransaction", fields: [recurringTransactionId], references: [id], onDelete: SetNull)
  recurringTransactionId String?

  @@unique([userId, importFingerprint])
  @@unique([recurringTransactionId, occurredAt])
  @@index([userId, occurredAt])
  @@index([userId, categoryId])
  @@index([userId, financialAccountId])
  @@index([userId, financialAccountId, cardStatementDate])
  @@index([userId, installmentGroupId])
  @@index([userId, reconciliationId])
  @@index([userId, appliedRuleId])
  @@map("transactions")
}

model CreditCardPayment {
  id              String   @id @default(cuid())
  userId          String
  creditCardId    String
  sourceAccountId String?
  statementDate   DateTime
  amount          Decimal  @db.Decimal(12, 2)
  paidAt          DateTime @default(now())
  source          String   @default("manual")
  externalMessageId String? @unique
  createdAt       DateTime @default(now())

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard    FinancialAccount  @relation("CreditCardPayments", fields: [creditCardId], references: [id], onDelete: Cascade)
  sourceAccount FinancialAccount? @relation("CreditCardPaymentSources", fields: [sourceAccountId], references: [id], onDelete: SetNull)

  @@index([userId, creditCardId, statementDate])
  @@index([userId, paidAt])
  @@map("credit_card_payments")
}

// Estado durável do processamento de cada mensagem recebida da Evolution API.
// O default COMPLETED preserva com segurança os registros criados antes da máquina de estados.
model WhatsappInboundMessage {
  id                  String                @id
  phone               String
  status              WhatsappInboundStatus @default(COMPLETED)
  attempts            Int                   @default(1)
  processingStartedAt DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  lastError           String?               @db.Text
  receivedAt          DateTime              @default(now())

  @@index([phone, receivedAt])
  @@index([status, processingStartedAt])
  @@map("whatsapp_inbound_messages")
}

model Budget {
  id           String  @id @default(cuid())
  userId       String
  categoryId   String
  monthlyLimit Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId]) // um orçamento por categoria por usuário
  @@map("budgets")
}

model RecurringTransaction {
  id         String  @id @default(cuid())
  userId     String
  categoryId String?

  amount      Decimal         @db.Decimal(12, 2)
  kind        TransactionKind
  description String?

  interval  RecurrenceInterval
  startDate DateTime
  endDate   DateTime?
  nextDate  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  transactions Transaction[] @relation("RecurringToTransaction")

  @@index([userId])
  @@index([nextDate])
  @@map("recurring_transactions")
}

model BillReminder {
  id                String    @id @default(cuid())
  userId            String
  description       String
  amount            Decimal   @db.Decimal(12, 2)
  dueDate           DateTime
  isPaid            Boolean   @default(false)
  paidAt            DateTime?
  snoozedUntil      DateTime?
  lastNotifiedAt    DateTime?
  notificationCount Int       @default(0)
  createdAt         DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dueDate])
  @@map("bill_reminders")
}

model FinancialGoal {
  id           String    @id @default(cuid())
  userId       String
  name         String
  icon         String    @default("🎯")
  targetAmount Decimal   @db.Decimal(12, 2)
  savedAmount  Decimal   @default(0) @db.Decimal(12, 2)
  targetDate   DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([userId, targetDate])
  @@map("financial_goals")
}

model TransactionRule {
  id                 String          @id @default(cuid())
  userId             String
  keyword            String
  kind               TransactionKind
  categoryId         String
  financialAccountId String?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  financialAccount FinancialAccount? @relation(fields: [financialAccountId], references: [id], onDelete: SetNull)
  transactions     Transaction[]

  @@index([userId, isActive])
  @@index([userId, kind])
  @@map("transaction_rules")
}

model AccountReconciliation {
  id                 String   @id @default(cuid())
  userId             String
  financialAccountId String
  statementDate      DateTime
  statementBalance   Decimal  @db.Decimal(12, 2)
  systemBalance      Decimal  @db.Decimal(12, 2)
  transactionCount   Int      @default(0)
  createdAt          DateTime @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialAccount FinancialAccount @relation(fields: [financialAccountId], references: [id], onDelete: Cascade)
  transactions     Transaction[]

  @@unique([financialAccountId, statementDate])
  @@index([userId, createdAt])
  @@map("account_reconciliations")
}

// =============================================================================
// WhatsApp
// =============================================================================

model WhatsappLinkCode {
  id        String    @id @default(cuid())
  userId    String
  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@map("whatsapp_link_codes")
}

// Estado temporário do cadastro iniciado pelo WhatsApp.
model WhatsappOnboardingSession {
  phone     String   @id
  step      String   @default("NAME") // NAME | EMAIL | EMAIL_CODE | CONFIRM
  name      String?
  email     String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("whatsapp_onboarding_sessions")
}

// Token de uso único para o novo usuário definir a senha fora do WhatsApp.
model AccountActivationToken {
  id        String    @id @default(cuid())
  userId    String    @unique
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash, expiresAt])
  @@map("account_activation_tokens")
}

// Status do bot central (única linha — upsert por id fixo "bot")
model BotConnection {
  id              String              @id @default("bot")
  status          BotConnectionStatus @default(DISCONNECTED)
  lastConnectedAt DateTime?
  updatedAt       DateTime            @updatedAt

  @@map("bot_connections")
}

// Sessão Baileys persistida no banco (evita perda em deploys com container efêmero)
model BotAuthState {
  id        String   @id // chave da sessão Baileys (ex.: "creds", "app-state-sync-key-*")
  data      String   @db.Text // JSON serializado
  updatedAt DateTime @updatedAt

  @@map("bot_auth_states")
}

// =============================================================================
// Monetização
// =============================================================================

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeSubscriptionId String             @unique
  status               SubscriptionStatus @default(INACTIVE)
  plan                 String // "free" | "pro"
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}
