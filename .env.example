# Database (Supabase PostgreSQL)
# Use a pooled URL at runtime and a direct URL only for migrations.
DATABASE_URL="postgres://user:password@host:6543/postgres?sslmode=require&pgbouncer=true"
DATABASE_URL_NON_POOLING="postgres://user:password@host:5432/postgres?sslmode=require"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="placeholder"
GOOGLE_CLIENT_SECRET="placeholder"

# E-mail transacional (EmailJS — usado somente no servidor)
EMAILJS_SERVICE_ID="service_xxxx"
EMAILJS_PUBLIC_KEY="your_public_key"
EMAILJS_PRIVATE_KEY="your_private_key"
EMAILJS_RESET_TEMPLATE_ID="template_xxxx"
EMAILJS_VERIFY_TEMPLATE_ID="template_xxxx"
EMAILJS_TIMEOUT_MS="10000"

# Stripe
STRIPE_SECRET_KEY="sk_test_xxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxx"
STRIPE_PRO_PRICE_ID="price_xxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxx"
STRIPE_TIMEOUT_MS="20000"

# Google Gemini
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_TIMEOUT_MS="25000"

# Evolution API / WhatsApp
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_PUBLIC_URL="https://evolution.example.com"
EVOLUTION_API_KEY="generate-a-long-random-secret"
EVOLUTION_INSTANCE_NAME="FinZapBot"
WHATSAPP_WEBHOOK_SECRET="generate-an-independent-long-random-secret"
EVOLUTION_TIMEOUT_MS="15000"

# Privacidade de mensagens
# Desabilitado por padrão. Se habilitado, identificadores diretos são mascarados.
STORE_RAW_MESSAGES="false"
# Aceita valores de 30 a 90 dias.
RAW_MESSAGE_RETENTION_DAYS="60"

# Cron endpoints
CRON_SECRET="generate-an-independent-long-random-secret"

# Redis local usado pelos containers da VM
REDIS_URL="redis://localhost:6379"

# Redis serverless persistente usado pelas funções da Vercel.
# A integração Upstash adiciona estes valores automaticamente.
UPSTASH_REDIS_REST_URL="https://your-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_rest_token"

# Limite global de chamadas ao Gemini por dia (horário de São Paulo).
GEMINI_DAILY_REQUEST_LIMIT="200"

# Docker-only database settings
# Never reuse these values in a public or managed database.
DOCKER_POSTGRES_USER="finzap"
DOCKER_POSTGRES_PASSWORD="generate-a-long-random-password"
DOCKER_POSTGRES_DB="finzap"

# Pin this to a tested Evolution release or image digest in production.
EVOLUTION_API_IMAGE="evoapicloud/evolution-api:latest"
