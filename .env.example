# =============================================================================
# FinZap — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env — ele já está no .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados (PostgreSQL)
# Para desenvolvimento local com Docker: postgresql://finzap:finzap@localhost:5432/finzap
# Para produção: use a URL do Neon/Supabase
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://finzap:finzap@localhost:5432/finzap"

# -----------------------------------------------------------------------------
# Redis (BullMQ)
# Para desenvolvimento local com Docker: redis://localhost:6379
# Para produção: use a URL do Upstash (formato: rediss://...)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Auth.js (NextAuth)
# Gere um secret seguro com: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="SUBSTITUA_POR_UM_SECRET_SEGURO"

# -----------------------------------------------------------------------------
# Google OAuth
# Obtenha em: https://console.cloud.google.com/
# 1. Crie um projeto > APIs e Serviços > Credenciais
# 2. Crie credenciais OAuth 2.0 para Aplicativo Web
# 3. URI de redirecionamento: http://localhost:3000/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="seu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-google-client-secret"

# -----------------------------------------------------------------------------
# Anthropic API (Parser de mensagens do WhatsApp — Claude Haiku)
# Obtenha em: https://console.anthropic.com/
# Deixe vazio para usar apenas o parser regex (sem LLM)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=""

# -----------------------------------------------------------------------------
# Stripe (Monetização — Fase 6)
# Obtenha em: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# -----------------------------------------------------------------------------
# Sentry (Monitoramento de erros — Fase 7)
# Obtenha em: https://sentry.io/
# -----------------------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# -----------------------------------------------------------------------------
# E-mail (Alertas e autenticação por magic link — opcional)
# Compatível com qualquer SMTP (Gmail, Resend, etc.)
# Para Gmail: use uma App Password
# -----------------------------------------------------------------------------
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="FinZap <noreply@finzap.app>"

# -----------------------------------------------------------------------------
# App (configurações gerais)
# -----------------------------------------------------------------------------
NODE_ENV="development"
# Número de WhatsApp do bot (formato: 5511999999999@s.whatsapp.net)
BOT_WHATSAPP_NUMBER=""
