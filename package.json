{
  "name": "finzap",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace=packages/database",
    "db:migrate:dev": "npm run db:migrate:dev --workspace=packages/database",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace=packages/database",
    "db:migrate:status": "npm run db:migrate:status --workspace=packages/database",
    "db:migrate:baseline": "npm run db:migrate:baseline --workspace=packages/database",
    "db:push": "npm run db:push --workspace=packages/database",
    "db:seed": "npm run db:seed --workspace=packages/database",
    "db:studio": "npm run db:studio --workspace=packages/database"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
