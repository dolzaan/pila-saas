# =============================================================================
# pnpm configuration — FinZap monorepo
# =============================================================================

# Usa node_modules flat (como npm/yarn) em vez de .pnpm/
# Isso evita o ERR_PNPM_EPERM causado por rename atômico de binários nativos
# no Windows com Windows Defender ativo.
node-linker=hoisted

# Hoista todos os pacotes para o root node_modules
# (necessário com node-linker=hoisted para compatibilidade máxima)
shamefully-hoist=true

# Permite build de pacotes nativos necessários
allow-build=@prisma/client
allow-build=prisma
allow-build=bcrypt
allow-build=esbuild
