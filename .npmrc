public-hoist-pattern[]=*
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma*

# Windows: usa 'copy' em vez de hardlinks para evitar EPERM em sistemas com antivírus
# Isso é mais lento mas necessário no Windows com Windows Defender ativo
package-import-method=copy

allow-build=@prisma/client
allow-build=prisma
allow-build=bcrypt
